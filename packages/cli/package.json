{
  "name": "@skelix/cli",
  "version": "0.1.0",
  "bin": {
    "skelix": "./dist/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --banner.js '#!/usr/bin/env node'",
    "dev": "tsup src/index.ts --format esm,cjs --dts --banner.js '#!/usr/bin/env node' --watch"
  },
  "dependencies": {
    "@skelix/core": "*",
    "@skelix/adapters": "*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4"
  }
}
