{
  "name": "skelix",
  "version": "0.1.0",
  "description": "CLI to auto-generate skeleton loading components from React components",
  "author": "Dushyant Pant <dushyantpant5@github>",
  "license": "MIT",
  "homepage": "https://github.com/dushyantpant5/skelix#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dushyantpant5/skelix.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/dushyantpant5/skelix/issues"
  },
  "keywords": ["skeleton", "shimmer", "react", "loading", "tailwind", "cli", "codegen"],
  "bin": {
    "skelix": "./dist/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@skelix/core": "*",
    "@skelix/adapters": "*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4"
  }
}
