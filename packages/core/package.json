{
  "name": "@skelix/core",
  "version": "0.1.0",
  "description": "Core parser, transformer, and generator for Skelix — auto-generate skeleton loading components from React components",
  "author": "Dushyant Pant <dushyantpant5@github>",
  "license": "MIT",
  "homepage": "https://github.com/dushyantpant5/skelix#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dushyantpant5/skelix.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/dushyantpant5/skelix/issues"
  },
  "keywords": ["skeleton", "shimmer", "react", "loading", "tailwind", "ast", "codegen"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@babel/parser": "^7.24.4",
    "@babel/traverse": "^7.24.4",
    "@babel/types": "^7.24.4",
    "prettier": "^3.2.5",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/fs-extra": "^11.0.4"
  }
}
