{
  "name": "skelix",
  "private": true,
  "author": "Dushyant Pant",
  "repository": {
    "type": "git",
    "url": "https://github.com/dushyantpant5/skelix.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/adapters && npm run build -w packages/cli",
    "dev": "npm run dev --workspaces --if-present",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "tsup": "^8.0.2",
    "@types/node": "^20.12.0"
  }
}
